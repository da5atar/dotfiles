# ---- Font ----
font-family = "VictorMono Nerd Font Mono"
font-size = 14

# ---- Theme ----
# https://ghostty.org/docs/features/theme
theme = Catppuccin Mocha

# ---- Window ----

# Background
window-height = 100
window-width = 100

background-opacity = 0.95
background-blur-radius = 20

window-padding-x = 10
window-padding-y = 10
window-padding-color = extend
window-padding-balance = true

window-decoration = true

window-step-resize = false

# ---- Shaders ----
# https://github.com/0xhckr/ghostty-shaders

# Config 1
# custom-shader = ./shaders/starfield-colors.glsl

# Config 2
custom-shader = ./shaders/matrix-hallway.glsl

# Config 3
# custom-shader = ./shaders/inside-the-matrix.glsl

# Cursor shaders
# https://github.com/sahaj-b/ghostty-cursor-shaders

# custom-shader = ./shaders/cursor_blaze.glsl
custom-shader = ./shaders/cursor_blaze_2.glsl
custom-shader = ./shaders/cursor_smear_gradient.glsl
custom-shader = ./shaders/ripple_cursor.glsl
# custom-shader = ./shaders/auto-tracking-spotlight

# ---- Keybindings ----

# macOS Alt key fix
macos-option-as-alt = left

# Unbindings
keybind = alt+left=unbind
keybind = alt+right=unbind

# Split Management
keybind = alt+/=new_split:right
keybind = alt+-=new_split:down
keybind = alt+q=close_surface
keybind = alt+z=toggle_fullscreen

# Split Navigation
keybind = alt+k=goto_split:up
keybind = alt+j=goto_split:down
keybind = alt+h=goto_split:left
keybind = alt+l=goto_split:right

# Split Resize
keybind = ctrl+shift+j=resize_split:up,10
keybind = ctrl+shift+k=resize_split:down,10
keybind = ctrl+shift+h=resize_split:left,10
keybind = ctrl+shift+l=resize_split:right,10

# Quake mode
keybind = global:ctrl+t=toggle_quick_terminal

# ---- Optimizations ----

# Copy
copy-on-select = false

# Save layout
window-save-state = always

# Performance optimization
shell-integration = detect

# ---- Theme ----

# --- Base Colors ---
background = 06080f
foreground = f3f6f9
cursor-color = e0c15a
selection-background = 263356
selection-foreground = f3f6f9

# --- Normal Colors ---
palette = 0=#06080f
palette = 1=#cb7c94
palette = 2=#b7cc85
palette = 3=#ffe066
palette = 4=#7fb4ca
palette = 5=#ff8dd7
palette = 6=#7aa89f
palette = 7=#f3f6f9

# --- Bright Colors ---
palette = 8=#8a8fa3
palette = 9=#de8fa8
palette = 10=#d1e8a9
palette = 11=#fff7b1
palette = 12=#a3d4d5
palette = 13=#ffaeea
palette = 14=#7fb4ca
palette = 15=#f3f6f9
