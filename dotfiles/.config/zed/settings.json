// File: ~/.config/zed/settings.json
// Description: Zed settings
// Computer: Dacomp
// Last Edit: 2026-02-01
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  // ────────────────────────────────────────────────
  // 1️⃣ Editor & Language Settings
  // ────────────────────────────────────────────────
  "diff_view_style": "split",
  "cli_default_open_behavior": "existing_window",
  "vim_mode": true,
  "colorize_brackets": true,
  "inlay_hints": {
    "show_background": true,
  },
  "show_signature_help_after_edits": true,
  "auto_signature_help": true,
  "wrap_guides": [25, 50, 80],
  "edit_predictions": {
    "mode": "subtle",
    "ollama": {
      "api_url": "",
      "model": "qwen3:4b",
    },
    "provider": "zed",
  },
  "languages": {
    "Markdown-Inline": {
      "auto_indent_on_paste": true,
      "linked_edits": true,
      "show_whitespaces": "all",
      "show_edit_predictions": true,
      "wrap_guides": [25, 50, 80],
      "soft_wrap": "editor_width",
      "indent_guides": {
        "enabled": false,
      },
      "hard_tabs": false,
    },
  },
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  "buffer_font_weight": 200.0,
  "buffer_font_size": 14,
  "buffer_font_family": "MonaspiceAr Nerd Font",
  "buffer_font_fallbacks": ["FiraCode Nerd Font", ".ZedMono"],
  "auto_indent_on_paste": true,
  "linked_edits": true,
  "show_whitespaces": "all",
  "show_edit_predictions": true,
  "soft_wrap": "editor_width",
  // ────────────────────────────────────────────────
  // 2️⃣ Cursor & Gutter
  // ────────────────────────────────────────────────
  "cursor_shape": "bar",
  "cursor_blink": true,
  "gutter": {
    "line_numbers": true,
  },
  "relative_line_numbers": "enabled",

  // ────────────────────────────────────────────────
  // 3️⃣ UI Layout & Appearance
  // ────────────────────────────────────────────────
  "minimap": {
    "show": "auto",
  },
  "tab_bar": {
    "show": true,
  },
  "scrollbar": {
    "show": "auto",
  },
  "tabs": {
    "file_icons": false,
    "show_diagnostics": "errors",
  },
  "indent_guides": {
    "background_coloring": "indent_aware",
    "enabled": false,
    "coloring": "indent_aware",
  },
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "theme": {
    "mode": "system",
    "light": "Ayu Light",
    "dark": "Ayu Dark",
  },
  "base_keymap": "VSCode",
  "ui_font_family": ".SystemUIFont",
  "ui_font_size": 14,

  // ────────────────────────────────────────────────
  // 4️⃣ Git & Project Panels
  // ────────────────────────────────────────────────
  "git_panel": {
    "tree_view": true,
    "dock": "right",
  },
  "project_panel": {
    "button": true,
    "dock": "left",
    "git_status": true,
  },
  "outline_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "left",
  },

  // ────────────────────────────────────────────────
  // 5️⃣ Agent & AI
  // ────────────────────────────────────────────────
  "agent": {
    "enable_feedback": true,
    "sidebar_side": "right",
    "dock": "right",
    "favorite_models": [
      {
        "provider": "oMLX-Qwen3.5",
        "model": "Qwen3.5-9B-OptiQ-4bit",
        "enable_thinking": false,
      },
    ],
    "default_profile": "write",
    "default_model": {
      "enable_thinking": false,
      "provider": "Llama",
      "model": "deepreinforce-ai/Ornith-1.0-9B-GGUF:Q4_K_M",
    },
    "use_modifier_to_send": true,
    "play_sound_when_agent_done": "when_hidden",
    "model_parameters": [],
  },
  "language_models": {
    "openai_compatible": {
      "Llama": {
        "api_url": "http://localhost:8085/v1",
        "available_models": [
          {
            "name": "gemma-4-e4b-it:Q8_0",
            "max_tokens": 64000,
            "max_output_tokens": 8192,
            "max_completion_tokens": 2048,
            "reasoning_effort": "medium",
            "capabilities": {
              "tools": true,
              "images": true,
              "parallel_tool_calls": true,
              "prompt_cache_key": false,
              "chat_completions": true,
              "interleaved_reasoning": false,
              "max_tokens_parameter": false,
            },
          },
          {
            "name": "deepreinforce-ai/Ornith-1.0-9B-GGUF:Q4_K_M",
            "max_tokens": 64000,
            "max_output_tokens": 8192,
            "max_completion_tokens": 2048,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
              "chat_completions": true,
              "interleaved_reasoning": false,
              "max_tokens_parameter": false,
            },
          },
        ],
      },
      "oMLX": {
        "api_url": "http://127.0.0.1:8084/v1",
        "available_models": [
          {
            "name": "Qwen3.5-9B-OptiQ-4bit",
            "max_tokens": 64000,
            "max_output_tokens": 8192,
            "max_completion_tokens": 2048,
            "capabilities": {
              "tools": true,
              "images": true,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
              "chat_completions": true,
              "interleaved_reasoning": false,
            },
          },
        ],
      },
    },
  },

  // ────────────────────────────────────────────────
  // 6️⃣ Context Servers
  // ────────────────────────────────────────────────
  "context_servers": {
    "mcp-server-tavily": {
      "enabled": true,
      "remote": false,
      "settings": {
        "tavily_api_key": "$tavily_api_key",
      },
    },
    "mcp-server-context7": {
      "enabled": true,
      "settings": {
        "context7_api_key": "",
      },
    },
  },

  // ────────────────────────────────────────────────
  // 7️⃣ Terminal
  // ────────────────────────────────────────────────
  "terminal": {
    "blinking": "on",
    "cursor_shape": "bar",
    "line_height": {
      "custom": 1.2,
    },
    "font_family": "MonaspiceKr Nerd Font",
    "font_fallbacks": ["3270 Nerd Font", ".ZedMono"],
    "font_size": 14.0,
    "env": {
      "EDITOR": "zed --wait",
    },
  },

  // ────────────────────────────────────────────────
  // 8️⃣ File Types & Scan Exclusions
  // ────────────────────────────────────────────────
  "file_types": {
    "Dockerfile": ["Dockerfile", "Dockerfile.*"],
    "JSON": ["json", "jsonc", "*.code-snippets"],
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/out",
    "**/dist",
    "**/.husky",
    "**/.turbo",
    "**/.vscode-test",
    "**/.vscode",
    "**/.next",
    "**/.storybook",
    "**/.tap",
    "**/.nyc_output",
    "**/report",
    "**/node_modules",
  ],

  // ────────────────────────────────────────────────
  // 9️⃣ Telemetry & Misc
  // ────────────────────────────────────────────────
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "redact_private_values": true,
  "preview_tabs": {
    "enabled": false,
  },
  "status_bar": {
    "experimental.show": true,
  },
  "multi_cursor_modifier": "cmd_or_ctrl",
}
